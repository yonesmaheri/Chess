generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(uuid())
  phone               String   @unique
  firstName           String
  lastName            String
  passwordHash        String
  refreshTokenHash    String?
  refreshTokenVersion Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([phone])
}
